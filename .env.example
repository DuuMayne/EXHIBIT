# AWS
AWS_PROFILE=default
AWS_REGION=us-east-1

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-org-name

# Okta
OKTA_DOMAIN=yourorg.okta.com
OKTA_API_TOKEN=00...

# Google (service account JSON path or OAuth credentials)
GOOGLE_CREDENTIALS_PATH=/path/to/service_account.json
# OR for OAuth flow:
# GOOGLE_OAUTH_CLIENT_SECRETS=/path/to/client_secrets.json
GOOGLE_DRIVE_OWNER_EMAIL=you@yourorg.com

# Jira / Confluence (Atlassian Cloud)
ATLASSIAN_DOMAIN=yourorg.atlassian.net
ATLASSIAN_EMAIL=you@yourorg.com
ATLASSIAN_API_TOKEN=...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Playwright Chrome profile (path to your existing Chrome user data dir)
# macOS default: ~/Library/Application Support/Google/Chrome
CHROME_USER_DATA_DIR=/Users/you/Library/Application Support/Google/Chrome
CHROME_PROFILE=Default
