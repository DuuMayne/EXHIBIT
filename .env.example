# AWS
AWS_PROFILE=default
AWS_REGION=us-east-1

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-org-name

# env0 (Settings → API Keys → Generate API Key; org ID from URL or leave blank to auto-detect)
ENV0_API_KEY=
ENV0_ORG_ID=

# Okta
OKTA_DOMAIN=yourorg.okta.com
OKTA_API_TOKEN=00...

# Google (service account JSON path or OAuth credentials)
GOOGLE_CREDENTIALS_PATH=/path/to/service_account.json
# OR for OAuth flow:
# GOOGLE_OAUTH_CLIENT_SECRETS=/path/to/client_secrets.json
GOOGLE_DRIVE_OWNER_EMAIL=you@yourorg.com

# Jira / Confluence (Atlassian Cloud)
ATLASSIAN_DOMAIN=yourorg.atlassian.net
ATLASSIAN_EMAIL=you@yourorg.com
ATLASSIAN_API_TOKEN=...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# CrowdStrike (Falcon console → Support → API Clients & Keys → Create API client)
# Required scopes: Hosts:read, Prevention Policies:read, Detections:read, Spotlight vulnerabilities:read
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# Cloudflare (dash.cloudflare.com → My Profile → API Tokens → Create Token)
# Required permissions: Zone:Read, Firewall Services:Read, Access: Apps and Policies:Read
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Snowflake
SNOWFLAKE_ACCOUNT=yourorg.us-east-1
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SECURITYADMIN

# Kandji (kandji.io → Settings → Access → Add API Token)
KANDJI_API_TOKEN=
KANDJI_SUBDOMAIN=yourorg

# Semgrep (semgrep.dev → Settings → Tokens → Create token)
SEMGREP_API_TOKEN=
SEMGREP_ORG_SLUG=

# Lacework (Lacework Console → Settings → API Keys → Create API Key)
# Download the JSON file; copy keyId and secret from it
LACEWORK_ACCOUNT=yourorg
LACEWORK_API_KEY=
LACEWORK_API_SECRET=

# Playwright Chrome profile (path to your existing Chrome user data dir)
# macOS default: ~/Library/Application Support/Google/Chrome
CHROME_USER_DATA_DIR=/Users/you/Library/Application Support/Google/Chrome
CHROME_PROFILE=Default
